---
import Layout from "../layouts/Layout.astro";
import { SITE_META } from "../consts";


---

<Layout title={SITE_META.title} description={SITE_META.desc}>
	<div class="">
		<div class="divide-y divide-gray-200 dark:divide-gray-400 space-y-2 pb-8 pt-6 md:space-y-4">
			<h2 class="my-4 text-2xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-3xl sm:leading-10 md:text-4xl md:leading-14">
				{SITE_META.title} - Coming Soon!
			</h2>
			<p class="mt-4 text-lg leading-7 text-gray-500 dark:text-gray-400">
				{SITE_META.desc}
			</p>
		</div>
	</div>
	
</Layout>
